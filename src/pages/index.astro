---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Button from "@/components/bearnie/button/Button.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" class="grow">
    <!-- Hero Section -->
    <section class="max-w-screen 2xl:max-w-350 mx-auto px-8 w-full py-12 lg:min-h-[calc(100vh-11.5rem)] lg:flex lg:flex-col lg:justify-center">
      <div class="max-w-sm text-center mx-auto text-balance">
        <h1 class="text-lg sm:text-xl md:text-2xl font-medium tracking-tight mt-12">
          {SITE.title}
        </h1>
        <p class="text-base text-muted-foreground mt-4">
          {SITE.desc}
        </p>

        {
          SOCIALS.length > 0 && (
            <div class="mt-6 flex items-center justify-center gap-4">
              <Socials />
            </div>
          )
        }

        <div class="flex items-center gap-2.5 mt-8 justify-center">
          <a href="/posts">
            <Button variant="default" size="sm">
              Read Posts
              <IconArrowRight class="size-4 rtl:-rotate-180" />
            </Button>
          </a>
          <a
            href="/rss.xml"
            class="inline-flex items-center justify-center whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:shrink-0 cursor-pointer border border-input bg-background hover:bg-accent hover:text-accent-foreground h-8 px-3 gap-2 text-xs [&_svg]:size-3 rounded-sm"
            aria-label="RSS Feed"
            title="RSS Feed"
          >
            <IconRss class="size-3" />
            RSS
          </a>
        </div>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section class="max-w-screen 2xl:max-w-350 mx-auto px-8 w-full py-8 border-t border-border">
          <h2 class="text-lg font-medium tracking-tight mb-6">Featured</h2>
          <ul class="space-y-6">
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section class="max-w-screen 2xl:max-w-350 mx-auto px-8 w-full py-8 border-t border-border">
          <h2 class="text-lg font-medium tracking-tight mb-6">Recent Posts</h2>
          <ul class="space-y-6">
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="max-w-screen 2xl:max-w-350 mx-auto px-8 w-full pb-12 text-center">
      <a href="/posts/" class="text-sm text-muted-foreground hover:text-foreground transition-colors inline-flex items-center gap-1">
        All Posts
        <IconArrowRight class="inline-block size-3 rtl:-rotate-180" />
      </a>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
